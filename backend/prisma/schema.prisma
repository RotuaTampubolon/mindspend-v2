generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgets      Budget[]
  transactions Transaction[]
  categories   Category[]
  checkIns     CheckIn[]

  @@map("users")
}

// ─────────────────────────────────────────
// BUDGET
// ─────────────────────────────────────────

model Budget {
  id          String   @id @default(cuid())
  userId      String
  month       Int
  year        Int
  totalAmount Decimal  @db.Decimal(15, 2)
  currency    String   @default("IDR")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryBudgets CategoryBudget[]

  @@unique([userId, month, year])
  @@map("budgets")
}

model CategoryBudget {
  id         String   @id @default(cuid())
  budgetId   String
  categoryId String
  amount     Decimal  @db.Decimal(15, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  budget   Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([budgetId, categoryId])
  @@map("category_budgets")
}

// ─────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────

model Category {
  id        String       @id @default(cuid())
  userId    String?
  name      String
  icon      String?
  color     String?
  type      CategoryType @default(EXPENSE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  categoryBudgets CategoryBudget[]

  @@map("categories")
}

enum CategoryType {
  INCOME
  EXPENSE
}

// ─────────────────────────────────────────
// TRANSACTION
// ─────────────────────────────────────────

model Transaction {
  id         String          @id @default(cuid())
  userId     String
  categoryId String?
  amount     Decimal         @db.Decimal(15, 2)
  type       TransactionType
  note       String?
  date       DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, categoryId])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ─────────────────────────────────────────
// CHECK-IN
// ─────────────────────────────────────────

model CheckIn {
  id            String        @id @default(cuid())
  userId        String
  period        CheckInPeriod
  month         Int
  year          Int
  week          Int?
  totalBudget   Decimal?      @db.Decimal(15, 2)
  totalSpent    Decimal       @db.Decimal(15, 2)
  totalIncome   Decimal       @db.Decimal(15, 2)
  adherenceRate Decimal?      @db.Decimal(5, 2)
  mood          Mood?
  reflection    String?
  aiInsight     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, year, month])
  @@map("check_ins")
}

enum CheckInPeriod {
  WEEKLY
  MONTHLY
}

enum Mood {
  GREAT
  OKAY
  STRESSED
  BAD
}